[iscript]
if(typeof TYRANO.kag.stat.f.charaname==="undefined"){TYRANO.kag.stat.f.charaname={}}if(typeof TYRANO.kag.tmp.charaname==="undefined"){TYRANO.kag.tmp.charaname={}}if(typeof TYRANO.kag.tmp.charaname.functions==="undefined"){TYRANO.kag.tmp.charaname.functions={}}TYRANO.kag.tmp.charaname.image_path="./data/others/plugin/charaname/image/";TYRANO.kag.tmp.charaname.screen_width=TYRANO.kag.config.scWidth;TYRANO.kag.tmp.charaname.screen_height=TYRANO.kag.config.scHeight;TYRANO.kag.tmp.charaname.z_index=999;
[endscript]
[loadjs storage="./plugin/charaname/function.js"]
[loadjs storage="./plugin/charaname/charaname.js"]
[iscript]
if($(".chara_name_area").length!=0){$(".chara_name_area").remove()}TYRANO.kag.stat.chara_ptext="chara_name_area";$("#root_layer_system").append("<div id='chara_name_area_wrap' style='disaplay:none;'><div class='chara_name_area'></div></div>");var $target=$("#chara_name_area_wrap");$target.css({position:"absolute"});TYRANO.kag.ftag.nextOrder_charaname=TYRANO.kag.ftag.nextOrder;TYRANO.kag.ftag.nextOrder=function(){if(TYRANO.kag.tmp.charaname.type=="image"){if(TYRANO.kag.stat.flag_ref_page==true){$("#chara_name_area_wrap").hide()}}TYRANO.kag.ftag.nextOrder_charaname()};var chara_ptext=TYRANO.kag.ftag.master_tag.chara_ptext;chara_ptext.start_charaname=chara_ptext.start;TYRANO.kag.tag.chara_ptext.start=function(c){if(typeof TYRANO.kag.stat.f.charaname.before_name==="undefined"){TYRANO.kag.stat.f.charaname.before_name=""}if(TYRANO.kag.tmp.charaname.type=="image"){if(TYRANO.kag.stat.f.charaname.before_name!=c.name){$("#chara_name_area_wrap").hide();if(c.name!=""){$("#chara_name_area_wrap").fadeIn(parseInt(TYRANO.kag.tmp.charaname.time))}}else{$("#chara_name_area_wrap").fadeIn(0)}}else{if(c.name==""){$("#chara_name_area_wrap").hide()}else{$("#chara_name_area_wrap").fadeIn(parseInt(TYRANO.kag.tmp.charaname.time))}}if(TYRANO.kag.tmp.charaname.type=="image"){TYRANO.kag.stat.f.charaname.before_name=c.name;if(TYRANO.kag.stat.jcharas[c.name]){c.name=TYRANO.kag.stat.jcharas[c.name]}TYRANO.kag.stat.f.chara_ptext_name=c.name;var d=TYRANO.kag.stat.charas[c.name];if(d){$("#chara_name_area_wrap").find("img").attr("src","./data/others/plugin/charaname/image/"+d.name+".png")}else{$("#chara_name_area_wrap").find("img").attr("src","./data/others/plugin/charaname/image/none.png")}}chara_ptext.start_charaname(c)};TYRANO.kag.layer.hideMessageLayers_charaname=TYRANO.kag.layer.hideMessageLayers;TYRANO.kag.layer.hideMessageLayers=function(){TYRANO.kag.layer.hideMessageLayers_charaname();if($(".chara_name_area").html()!==""){$("#chara_name_area_wrap").hide()}};TYRANO.kag.layer.showMessageLayers_charaname=TYRANO.kag.layer.showMessageLayers;TYRANO.kag.layer.showMessageLayers=function(){TYRANO.kag.layer.showMessageLayers_charaname();if($(".chara_name_area").html()!==""){$("#chara_name_area_wrap").show()}};var sleepgame=TYRANO.kag.ftag.master_tag.sleepgame;sleepgame.start_charaname=sleepgame.start;TYRANO.kag.tag.sleepgame.start=function(a){TYRANO.kag.tmp.charaname.visible=$("#chara_name_area_wrap").css("display");$("#chara_name_area_wrap").hide();sleepgame.start_charaname(a)};
[endscript]
[return]
